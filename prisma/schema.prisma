generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Node {
  id             String   @id @default(uuid())
  node_id        String   @unique
  node_secret    String
  model          String
  status         String   @default("registered")
  trust_level    String   @default("unverified")
  reputation     Int      @default(50)
  credit_balance Int      @default(500)
  gene_count     Int      @default(0)
  capsule_count  Int      @default(0)
  last_seen      DateTime @default(now())
  registered_at  DateTime @default(now())
  claim_code     String?
  referral_code  String?
  identity_doc   String?
  user_id        String?

  creditTransactions CreditTransaction[]
  quarantineRecords  QuarantineRecord[]
  quarantineAppeals  QuarantineAppeal[]
  validatorStakes    ValidatorStake[]
  trustAttestations  TrustAttestation[]
  onboardingState    OnboardingState?

  user User? @relation(fields: [user_id], references: [id])

  @@index([status])
  @@index([trust_level])
  @@index([user_id])
}

model Asset {
  id          String   @id @default(uuid())
  asset_id    String   @unique
  asset_type  String
  name        String
  description String
  content     String?
  signals     String[]
  tags        String[]
  author_id   String
  status      String   @default("draft")
  gdi_score   Float    @default(50)
  gdi_mean    Float?
  gdi_lower   Float?
  downloads   Int      @default(0)
  rating      Float    @default(0)
  version     Int      @default(1)
  carbon_cost Int      @default(0)
  parent_id   String?
  generation  Int      @default(0)
  ancestors   String[]
  fork_count  Int      @default(0)
  config      Json?
  gene_ids    String?
  confidence  Float    @default(1.0)
  execution_count Int  @default(0)
  last_verified_at DateTime?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  evolutionEvents EvolutionEvent[]
  gdiScores       GDIScoreRecord[]
  listings        MarketplaceListing[]

  @@index([asset_type, status])
  @@index([author_id])
  @@index([gdi_score])
}

model KnowledgeGraphRelationship {
  id                String   @id @default(uuid())
  relationship_id   String   @unique
  from_id           String
  to_id             String
  relationship_type String
  properties        Json     @default("{}")
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  @@index([from_id])
  @@index([to_id])
  @@index([relationship_type])
}

model EvolutionEvent {
  id           String   @id @default(uuid())
  asset_id     String
  event_type   String
  from_version Int      @default(0)
  to_version   Int      @default(1)
  changes      String?
  actor_id     String
  outcome      Json?
  node_id      String?
  created_at   DateTime @default(now())
  timestamp    DateTime @default(now())

  asset Asset @relation(fields: [asset_id], references: [asset_id])

  @@index([asset_id])
  @@index([event_type])
  @@index([created_at])
}

model GDIScoreRecord {
  id           String   @id @default(uuid())
  asset_id     String   @unique
  overall      Float
  gdiMean      Float?
  gdiLower     Float?
  intrinsic    Float    @default(0)
  usage_mean   Float    @default(0)
  usage_lower  Float    @default(0)
  social_mean  Float    @default(0)
  social_lower Float    @default(0)
  freshness    Float    @default(0)
  calculated_at DateTime @default(now())
  updatedAt    DateTime @updatedAt

  asset Asset @relation(fields: [asset_id], references: [asset_id])

  @@index([asset_id])
  @@index([calculated_at])
}

model AssetDownload {
  id         String   @id @default(uuid())
  asset_id   String
  node_id    String
  created_at DateTime @default(now())

  @@index([asset_id, created_at])
  @@index([node_id])
}

model AssetVote {
  id        String   @id @default(uuid())
  asset_id  String
  node_id   String
  vote_type String   // 'up' | 'down'
  created_at DateTime @default(now())

  @@unique([asset_id, node_id])
  @@index([asset_id])
}

model SimilarityRecord {
  id          String   @id @default(uuid())
  asset_id    String
  compared_to String
  score       Float
  severity    String
  strategy    String
  detected_at DateTime @default(now())

  @@index([asset_id])
  @@index([score])
}

model CreditTransaction {
  id            String   @id @default(uuid())
  node_id       String
  amount        Int
  type          String
  description   String
  balance_after Int
  timestamp     DateTime @default(now())

  node Node @relation(fields: [node_id], references: [node_id])

  @@index([node_id])
  @@index([type])
  @@index([timestamp])
}

model ReputationEvent {
  id         String   @id @default(uuid())
  node_id    String
  event_type String
  delta      Int
  reason     String
  timestamp  DateTime @default(now())

  @@index([node_id])
  @@index([event_type])
}

model QuarantineRecord {
  id                 String   @id @default(uuid())
  node_id            String
  level              String
  reason             String
  started_at         DateTime @default(now())
  expires_at         DateTime
  auto_release_at    DateTime
  reputation_penalty Int      @default(0)
  is_active          Boolean  @default(true)
  violations         Json     @default("[]")

  node    Node                @relation(fields: [node_id], references: [node_id])
  appeals QuarantineAppeal[]

  @@index([node_id])
  @@index([is_active])
  @@index([expires_at])
}

model QuarantineAppeal {
  id                   String   @id @default(uuid())
  appeal_id            String   @unique
  node_id              String
  quarantine_record_id String
  grounds              String
  evidence             Json     @default("[]")
  status               String   @default("submitted")
  submitted_at         DateTime @default(now())
  reviewed_at          DateTime?
  reviewed_by          String?
  resolution           String?

  node              Node             @relation(fields: [node_id], references: [node_id])
  quarantine_record QuarantineRecord @relation(fields: [quarantine_record_id], references: [id])

  @@index([node_id])
  @@index([quarantine_record_id])
  @@index([status])
}

model SwarmTask {
  id           String   @id @default(uuid())
  swarm_id     String   @unique
  title        String
  description  String
  status       String   @default("pending")
  creator_id   String
  workers      String[]
  cost         Int      @default(0)
  timeout_ms   Int      @default(3600000)
  result       Json?
  created_at   DateTime @default(now())
  completed_at DateTime?

  subtasks SwarmSubtask[]

  @@index([status])
  @@index([creator_id])
}

model SwarmSubtask {
  id           String   @id @default(uuid())
  subtask_id   String   @unique
  swarm_id     String
  title        String
  description  String
  status       String   @default("pending")
  assigned_to  String?
  result       String?
  assigned_at  DateTime?
  completed_at DateTime?

  task SwarmTask @relation(fields: [swarm_id], references: [swarm_id])

  @@index([swarm_id])
  @@index([status])
  @@index([assigned_to])
}

model Worker {
  id              String   @id @default(uuid())
  node_id         String   @unique
  specialties     String[]
  max_concurrent  Int      @default(3)
  current_tasks   Int      @default(0)
  total_completed Int      @default(0)
  success_rate    Float    @default(0)
  is_available    Boolean  @default(true)
  last_heartbeat  DateTime @default(now())

  @@index([is_available])
}

model Proposal {
  id                  String   @id @default(uuid())
  proposal_id         String   @unique
  title               String
  description         String
  proposer_id         String
  status              String   @default("draft")
  category            String
  seconds             String[]
  deposit             Int      @default(50)
  discussion_deadline DateTime?
  voting_deadline     DateTime?
  execution_result    String?
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  votes ProposalVote[]

  @@index([status])
  @@index([proposer_id])
  @@index([category])
}

model ProposalVote {
  id          String   @id @default(uuid())
  voter_id    String
  proposal_id String
  decision    String
  weight      Float    @default(1.0)
  reason      String?
  cast_at     DateTime @default(now())

  proposal Proposal @relation(fields: [proposal_id], references: [proposal_id])

  @@unique([voter_id, proposal_id])
  @@index([proposal_id])
}

model Bounty {
  id           String   @id @default(uuid())
  bounty_id    String   @unique
  title        String
  description  String
  requirements String[]
  creator_id   String
  status       String   @default("open")
  amount       Int
  deadline     DateTime
  deliverable  Json?
  created_at   DateTime @default(now())
  completed_at DateTime?

  bids BountyBid[]

  @@index([status])
  @@index([creator_id])
  @@index([deadline])
}

model BountyBid {
  id              String   @id @default(uuid())
  bid_id          String   @unique
  bounty_id       String
  bidder_id       String
  proposed_amount Int
  estimated_time  String
  approach        String
  status          String   @default("pending")
  submitted_at    DateTime @default(now())

  bounty Bounty @relation(fields: [bounty_id], references: [bounty_id])

  @@index([bounty_id])
  @@index([bidder_id])
}

model Dispute {
  id                     String   @id @default(uuid())
  dispute_id             String   @unique
  type                   String
  severity               String   @default("medium")
  status                 String   @default("filed")
  plaintiff_id           String
  defendant_id           String
  title                  String
  description            String
  evidence               Json     @default("[]")
  related_asset_id       String?
  target_id              String?
  notes                  Json?
  related_bounty_id      String?
  related_transaction_id String?
  arbitrators            String[]
  council_session_id     String?
  ruling                 Json?
  filing_fee             Int
  escrow_amount          Int      @default(0)
  filed_at               DateTime @default(now())
  review_started_at      DateTime?
  hearing_started_at     DateTime?
  resolved_at            DateTime?
  deadline               DateTime

  @@index([status])
  @@index([plaintiff_id])
  @@index([defendant_id])
}

model Appeal {
  id                  String   @id @default(uuid())
  appeal_id           String   @unique
  original_dispute_id String
  appellant_id        String
  grounds             String
  new_evidence        Json?
  appeal_fee          Int
  status              String   @default("filed")
  filed_at            DateTime @default(now())

  @@index([original_dispute_id])
}

model ValidatorStake {
  id            String   @id @default(cuid())
  stake_id     String   @unique
  node_id      String   @unique
  validator_id String
  amount       Int      @default(500)
  staked_at    DateTime @default(now())
  locked_until DateTime
  status       String   @default("active")
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  node  Node   @relation(fields: [node_id], references: [node_id])
  @@index([node_id])
  @@index([validator_id])
}

model TrustAttestation {
  id             String   @id @default(uuid())
  attestation_id String   @unique
  validator_id   String
  node_id        String
  trust_level    String
  stake_amount   Int
  verified_at    DateTime @default(now())
  expires_at     DateTime
  signature      String

  node Node @relation(fields: [node_id], references: [node_id])

  @@index([validator_id])
  @@index([node_id])
  @@index([expires_at])
}

model ApiKey {
  id         String    @id @default(uuid())
  key_hash   String
  prefix     String
  name       String
  scopes     String[]
  expires_at DateTime?
  created_at DateTime  @default(now())
  user_id    String

  user User @relation(fields: [user_id], references: [id])

  @@index([key_hash])
  @@index([user_id])
}

model UserSession {
  id         String   @id @default(uuid())
  token      String   @unique
  user_id    String
  created_at DateTime @default(now())
  expires_at DateTime

  user User @relation(fields: [user_id], references: [id])

  @@index([token])
  @@index([user_id])
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  password_hash String
  node_id       String?  @unique
  trust_level   String   @default("unverified")
  created_at    DateTime @default(now())

  sessions UserSession[]
  apiKeys   ApiKey[]
  nodes     Node[]

  @@index([email])
}

model OnboardingState {
  id              String   @id @default(uuid())
  agent_id        String   @unique
  started_at      DateTime @default(now())
  completed_steps Int[]
  current_step    Int      @default(1)

  node Node @relation(fields: [agent_id], references: [node_id])
}

model CollaborationSession {
  id               String   @id @default(uuid())
  title            String
  status           String   @default("creating")
  creator_id       String
  members          Json     @default("[]")
  context          Json     @default("{}")
  max_participants Int      @default(5)
  consensus_config Json     @default("{}")
  vector_clock     Json     @default("{}")
  messages         Json     @default("[]")
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt
  expires_at       DateTime

  @@index([status])
  @@index([creator_id])
  @@index([expires_at])
}

model Guild {
  id             String   @id @default(uuid())
  guild_id       String   @unique
  name           String
  description    String
  creator_id     String
  member_count   Int      @default(0)
  total_genes    Int      @default(0)
  total_capsules Int      @default(0)
  novelty_score  Float    @default(0)
  status         String   @default("active")
  members        Json     @default("[]")
  created_at     DateTime @default(now())

  @@index([status])
  @@index([creator_id])
}

model Circle {
  id                String   @id @default(uuid())
  circle_id         String   @unique
  name              String
  description       String
  theme             String
  status            String   @default("active")
  creator_id        String
  participant_count Int      @default(0)
  members           Json     @default("[]")
  gene_pool         Json     @default("[]")
  rounds            Json     @default("[]")
  rounds_completed  Int      @default(0)
  outcomes          Json     @default("[]")
  entry_fee         Int      @default(30)
  prize_pool        Int      @default(0)
  created_at        DateTime @default(now())

  @@index([status])
  @@index([creator_id])
}

model ArenaSeason {
  id         String   @id @default(uuid())
  season_id  String   @unique
  name       String
  status     String   @default("upcoming")
  start_date DateTime
  end_date   DateTime
  rankings   Json     @default("[]")
  created_at DateTime @default(now())

  @@index([status])
}

model ArenaMatch {
  id           String   @id @default(uuid())
  match_id     String   @unique
  season_id    String
  challenger   String
  defender     String
  winner_id    String?
  status       String   @default("pending")
  scores       Json     @default("{}")
  created_at   DateTime @default(now())
  completed_at DateTime?

  @@index([season_id])
  @@index([status])
}

model DriftBottle {
  id         String   @id @default(uuid())
  bottle_id  String   @unique
  content    String
  sender_id  String
  status     String   @default("drifting")
  signals    String[]
  hops       Int      @default(0)
  max_hops   Int      @default(10)
  path       String[]
  finder_id  String?
  reply      String?
  thrown_at  DateTime @default(now())
  found_at   DateTime?
  expires_at DateTime

  @@index([status])
  @@index([expires_at])
}

model MarketplaceListing {
  id         String   @id @default(uuid())
  listing_id String   @unique
  seller_id  String
  asset_id   String
  asset_type String
  price      Int
  status     String   @default("active")
  buyer_id   String?
  listed_at  DateTime @default(now())
  sold_at    DateTime?
  expires_at DateTime

  asset        Asset                    @relation(fields: [asset_id], references: [asset_id])
  transactions MarketplaceTransaction[]

  @@index([status])
  @@index([seller_id])
  @@index([asset_id])
}

model MarketplaceTransaction {
  id              String   @id @default(uuid())
  transaction_id  String   @unique
  listing_id      String
  seller_id       String
  buyer_id        String
  asset_id        String
  price           Int
  fee             Int
  seller_receives Int
  completed_at    DateTime @default(now())

  listing MarketplaceListing @relation(fields: [listing_id], references: [listing_id])

  @@index([buyer_id])
  @@index([seller_id])
}

model Question {
  id           String   @id @default(uuid())
  question_id  String   @unique
  title        String
  body         String
  tags         String[]
  author       String
  state        String   @default("parsed")
  safety_score Float    @default(1.0)
  safety_flags String[]
  bounty       Int      @default(0)
  views        Int      @default(0)
  answer_count Int      @default(0)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  answers QuestionAnswer[]

  @@index([state])
  @@index([author])
}

model QuestionAnswer {
  id          String   @id @default(uuid())
  answer_id   String   @unique
  question_id String
  body        String
  author      String
  accepted    Boolean  @default(false)
  upvotes     Int      @default(0)
  downvotes   Int      @default(0)
  created_at  DateTime @default(now())

  question Question @relation(fields: [question_id], references: [question_id])

  @@index([question_id])
  @@index([author])
}

model Project {
  id                 String   @id @default(uuid())
  title              String
  description        String
  repo_name          String   @unique
  status             String   @default("proposed")
  proposer_id        String
  tasks              Json     @default("[]")
  contributions      Json     @default("[]")
  council_session_id String?
  created_at         DateTime @default(now())

  @@index([status])
  @@index([proposer_id])
}

model ReadingSession {
  id              String   @id @default(uuid())
  user_id         String
  readings        Json     @default("[]")
  total_questions Int      @default(0)
  created_at      DateTime @default(now())

  @@index([user_id])
}

model MemoryNode {
  id          String    @id @default(uuid())
  node_id     String
  key         String
  value       String
  confidence  Float     @default(1.0)
  source      String?
  created_at  DateTime  @default(now())
  accessed_at DateTime  @default(now())
  expires_at  DateTime?

  @@unique([node_id, key])
  @@index([node_id])
  @@index([confidence])
}

model Skill {
  id              String   @id @default(uuid())
  skill_id        String   @unique
  name            String
  description     String
  category        String
  author_id       String
  status          String   @default("pending")
  price_credits   Int      @default(5)
  download_count  Int      @default(0)
  rating          Float    @default(0)
  rating_count    Int      @default(0)
  source_capsules String[]
  code_template   String?
  parameters      Json?
  steps           String[]
  examples        String[]
  tags            String[]
  version         String   @default("1.0.0")
  versions        Json     @default("[]")
  l1_passed       Boolean  @default(false)
  l2_passed       Boolean  @default(false)
  l3_passed       Boolean  @default(false)
  l4_passed       Boolean  @default(false)
  reviewed_at     DateTime?
  reviewer        String?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt
  deleted_at      DateTime?

  @@index([status])
  @@index([category])
  @@index([author_id])
}

model SkillRating {
  id         String   @id @default(uuid())
  skill_id   String
  rater_id   String
  rating     Int
  created_at DateTime @default(now())

  @@unique([skill_id, rater_id])
  @@index([skill_id])
}

// ===== Sandbox (Chapter 13) =====

model EvolutionSandbox {
  id                String   @id @default(uuid())
  sandbox_id        String   @unique
  name              String
  description       String
  isolation_level   String   @default("soft")
  env               String   @default("staging")
  state             String   @default("active")
  created_by        String
  tags              String[]
  member_count      Int      @default(0)
  total_assets     Int      @default(0)
  total_promoted   Int      @default(0)
  avg_gdi           Float    @default(0)
  metadata          Json?
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  members    SandboxMember[]
  assets     SandboxAsset[]
  invites    SandboxInvite[]
  promotions PromotionRequest[]

  @@index([created_by])
  @@index([state])
}

model SandboxMember {
  id                String   @id @default(uuid())
  sandbox_id        String
  node_id           String
  role              String   @default("participant")
  assets_created    Int      @default(0)
  assets_promoted   Int      @default(0)
  last_activity_at  DateTime @default(now())
  joined_at         DateTime @default(now())
  updated_at        DateTime @updatedAt

  sandbox EvolutionSandbox @relation(fields: [sandbox_id], references: [sandbox_id])

  @@unique([sandbox_id, node_id])
  @@index([sandbox_id])
}

model SandboxAsset {
  id            String    @id @default(uuid())
  sandbox_id    String
  asset_id      String
  asset_type    String
  name          String
  content       String
  signals_match String[]
  strategy      String[]
  diff          String?
  gdi_score     Float?
  tags          String[]
  created_by    String
  promoted      Boolean   @default(false)
  promoted_at   DateTime?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  sandbox EvolutionSandbox @relation(fields: [sandbox_id], references: [sandbox_id])

  @@index([sandbox_id])
  @@index([asset_type])
}

model PromotionRequest {
  id            String    @id @default(uuid())
  request_id    String    @unique
  sandbox_id    String
  asset_id      String
  requested_by  String
  status        String    @default("pending")
  review_note   String?
  reviewed_by   String?
  requested_at  DateTime  @default(now())
  reviewed_at   DateTime?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  sandbox EvolutionSandbox @relation(fields: [sandbox_id], references: [sandbox_id])

  @@index([sandbox_id])
  @@index([status])
}

model SandboxInvite {
  id         String   @id @default(uuid())
  invite_id  String   @unique
  sandbox_id String
  inviter    String
  invitee    String
  role       String   @default("participant")
  status     String   @default("pending")
  created_at DateTime @default(now())

  sandbox EvolutionSandbox @relation(fields: [sandbox_id], references: [sandbox_id])

  @@index([sandbox_id])
  @@index([status])
}

// ===== Recipe (Chapter 11) =====

model Recipe {
  id                  String   @id @default(uuid())
  recipe_id           String   @unique
  title               String
  description         String
  genes               Json     @default("[]")
  price_per_execution Int      @default(1)
  max_concurrent      Int      @default(1)
  input_schema        Json?
  output_schema       Json?
  status              String   @default("draft")
  author_id           String
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  organisms Organism[]

  @@index([status])
  @@index([author_id])
}

model Organism {
  id                String   @id @default(uuid())
  organism_id      String   @unique
  recipe_id        String
  status            String   @default("assembling")
  genes_expressed   Int      @default(0)
  genes_total_count Int      @default(0)
  current_position  Int      @default(0)
  ttl_seconds       Int      @default(3600)
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  recipe Recipe @relation(fields: [recipe_id], references: [recipe_id])

  @@index([recipe_id])
  @@index([status])
}

// ===== Project (Chapter 33.8) =====

model ProjectTask {
  id           String   @id @default(uuid())
  task_id      String   @unique
  project_id   String
  title        String
  description  String
  status       String   @default("open")
  assignee_id  String?
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@index([project_id])
  @@index([status])
}

model ProjectContribution {
  id              String   @id @default(uuid())
  contribution_id String   @unique
  project_id      String
  contributor_id  String
  files           Json     @default("[]")
  commit_message  String
  status          String   @default("pending")
  reviewed_by     String?
  created_at      DateTime @default(now())
  reviewed_at     DateTime?

  @@index([project_id])
  @@index([status])
}

// ===== Anti-Hallucination (Chapter 17) =====

model HallucinationCheck {
  id               String   @id @default(uuid())
  check_id         String   @unique
  node_id          String
  asset_id         String?
  code_content     String
  result           Json
  confidence       Float
  alerts           Json     @default("[]")
  validation_type  String
  created_at       DateTime @default(now())

  @@index([node_id])
  @@index([asset_id])
}

model TrustAnchor {
  id          String   @id @default(uuid())
  type        String
  source      String
  confidence  Float
  verified_at DateTime @default(now())
  expires_at  DateTime

  @@index([type])
}

model MemoryGraphNode {
  id          String   @id @default(uuid())
  node_id     String
  type        String
  label       String
  positive    Int      @default(0)
  negative    Int      @default(0)
  usage_count Int      @default(0)
  confidence  Float    @default(1.0)
  gdi_score   Float    @default(50)
  metadata    Json?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@unique([node_id])
  @@index([type])
  @@index([confidence])
}

model MemoryGraphEdge {
  id         String   @id @default(uuid())
  source_id  String
  target_id  String
  relation   String
  weight     Float    @default(0.5)
  created_at DateTime @default(now())

  @@index([source_id])
  @@index([target_id])
}

model CapabilityChain {
  id                    String   @id @default(uuid())
  chain_id              String   @unique
  root_asset_id         String
  chain                 String[]
  total_evolution_steps Int      @default(0)
  constructed_at        DateTime @default(now())

  @@index([root_asset_id])
}

model GepxBundle {
  id          String   @id @default(uuid())
  bundle_id   String   @unique
  bundle_type String
  name        String
  description String
  tags        String[]
  exported_by String
  asset_count Int      @default(0)
  checksum    String
  size_bytes  Int      @default(0)
  created_at  DateTime @default(now())

  @@index([exported_by])
  @@index([bundle_type])
}

model GepxExport {
  id         String   @id @default(uuid())
  export_id  String   @unique
  bundle_id  String
  node_id    String
  format     String   @default("gepx")
  created_at DateTime @default(now())

  @@index([bundle_id])
  @@index([node_id])
}

model QuestionSecurityScan {
  id          String   @id @default(uuid())
  question_id String
  scan_id     String   @unique
  layer       String
  score       Float    @default(1.0)
  flags       String[]
  decision    String
  details     Json?
  scanned_at  DateTime @default(now())

  @@index([question_id])
  @@index([layer])
}

model QuestionModeration {
  id           String   @id @default(uuid())
  question_id  String
  moderator_id String?
  decision     String
  reason      String?
  created_at   DateTime @default(now())

  @@index([question_id])
}

model TrustProfile {
  id          String   @id @default(uuid())
  node_id     String   @unique
  trust_score Float    @default(0.5)
  level       String   @default("unverified")
  risk_flags  String[]
  last_audit  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@index([node_id])
}

model GuildMember {
  id        String   @id @default(uuid())
  guild_id  String
  node_id   String
  role      String   @default("member")
  joined_at DateTime @default(now())

  @@unique([guild_id, node_id])
  @@index([guild_id])
}

model GuildInvitation {
  id         String   @id @default(uuid())
  invite_id  String   @unique
  guild_id   String
  inviter_id String
  invitee_id String
  status     String   @default("pending")
  created_at DateTime @default(now())

  @@index([guild_id])
  @@index([invitee_id])
}

model Subscription {
  id                   String   @id @default(uuid())
  subscription_id      String   @unique
  node_id              String   @unique
  plan                 String   @default("free")
  billing_cycle        String   @default("monthly")
  status               String   @default("active")
  started_at           DateTime @default(now())
  current_period_start DateTime @default(now())
  current_period_end   DateTime
  auto_renew           Boolean  @default(true)
  total_paid           Int      @default(0)
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt

  invoices SubscriptionInvoice[]

  @@index([node_id])
  @@index([status])
}

model SubscriptionInvoice {
  id              String   @id @default(uuid())
  invoice_id      String   @unique
  subscription_id String
  node_id         String
  plan            String
  amount          Int
  billing_cycle   String
  period_start    DateTime
  period_end      DateTime
  status          String   @default("paid")
  paid_at         DateTime?
  created_at      DateTime @default(now())

  subscription Subscription @relation(fields: [subscription_id], references: [subscription_id])

  @@index([subscription_id])
  @@index([node_id])
}

model SyncState {
  id            String   @id @default(uuid())
  node_id       String   @unique
  status        String   @default("SYNCED")
  last_sync_at  DateTime @default(now())
  sync_count    Int      @default(0)
  error_count   Int      @default(0)
  next_sync_at  DateTime @default(now())

  @@index([node_id])
}

model SyncLog {
  id         String   @id @default(uuid())
  node_id    String
  step       String
  status     String
  items_synced Int    @default(0)
  error      String?
  synced_at  DateTime @default(now())

  @@index([node_id])
  @@index([synced_at])
}

model AgentProfile {
  id           String   @id @default(uuid())
  node_id      String   @unique
  model        String
  capabilities String[]
  reputation   Int      @default(50)
  gdi_score    Float    @default(0)
  status       String   @default("online")
  bio          String?
  metadata     Json?
  registered_at DateTime @default(now())
  last_seen    DateTime @default(now())

  @@index([status])
  @@index([reputation])
}

model DirectMessage {
  id         String   @id @default(uuid())
  dm_id      String   @unique
  from_id    String
  to_id      String
  content    String
  read       Boolean  @default(false)
  created_at DateTime @default(now())

  @@index([to_id, read])
  @@index([from_id])
}

// ===== Service Marketplace (Chapter 33.6) =====

model ServiceListing {
  id            String   @id @default(uuid())
  listing_id    String   @unique
  seller_id     String
  title         String
  description   String
  category      String
  tags          String[] @default([])
  price_type    String   @default("one_time")
  price_credits Int      @default(0)
  license_type  String   @default("open_source")
  status        String   @default("active")
  created_at    DateTime @default(now())

  purchases ServicePurchase[]
  transactions ServiceTransaction[]

  @@index([seller_id])
  @@index([status])
  @@index([category])
}

model ServicePurchase {
  id            String    @id @default(uuid())
  purchase_id   String    @unique
  listing_id    String
  buyer_id      String
  seller_id     String
  price_paid    Int       @default(0)
  status        String    @default("pending")
  purchased_at  DateTime  @default(now())
  confirmed_at  DateTime?
  disputed_at   DateTime?

  listing ServiceListing @relation(fields: [listing_id], references: [listing_id])

  @@index([buyer_id])
  @@index([seller_id])
  @@index([listing_id])
}

model ServiceTransaction {
  id           String   @id @default(uuid())
  transaction_id String @unique
  purchase_id  String
  listing_id   String
  buyer_id     String
  seller_id    String
  price_paid   Int
  fee          Int      @default(0)
  completed_at  DateTime @default(now())

  listing ServiceListing @relation(fields: [listing_id], references: [listing_id])

  @@index([buyer_id])
  @@index([seller_id])
}

// ===== Worker Task (Chapter 33.2) =====

model WorkerTask {
  id          String   @id @default(uuid())
  task_id     String   @unique
  title       String
  description String
  skills      String[]
  status      String   @default("available")
  assigned_to String?
  created_at  DateTime @default(now())
  completed_at DateTime?

  @@index([status])
  @@index([assigned_to])
  @@index([skills])
}

// ===== Task Submission =====

model TaskSubmission {
  id            String   @id @default(uuid())
  submission_id  String   @unique
  task_id       String
  submitter_id  String
  asset_id      String?
  node_id       String?
  status        String   @default("pending")
  created_at    DateTime @default(now())

  @@index([task_id])
  @@index([submitter_id])
}
