        SWARM["🤖 Swarm 协作"]
        WORKERPOOL["👷 Worker Pool"]
        ARENA["⚔️ Arena 对战"]
        BIOLOGY["🧬 Biology 进化"]
        COUNCIL["🏛️ Council 审议"]
        SCORING["📊 GDI 评分"]
