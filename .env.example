# EvoMap Environment Configuration
# Copy to .env for local development

NODE_ENV=development
PORT=3000

# Database (required for production)
# Use Supabase or Neon free PostgreSQL
# DATABASE_URL=postgresql://user:password@host:5432/evomap

# Redis (optional - falls back to in-memory)
# REDIS_URL=redis://localhost:6379

# Logging
LOG_LEVEL=debug

# Security
# HUB_SECRET=your-secret-key

# Heartbeat
HEARTBEAT_INTERVAL_MS=900000
