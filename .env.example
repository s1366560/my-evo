# ============================================================
# EvoMap Hub - Environment Variables Template
# Copy this file to .env and fill in your values
# Usage: cp .env.example .env
# ============================================================

# ============================================================
# SERVER
# ============================================================

# HTTP server port (default: 3001)
PORT=3001

# Server bind address (default: 0.0.0.0 = all interfaces)
HOST=0.0.0.0

# Log verbosity: trace, debug, info, warn, error, fatal (default: info)
LOG_LEVEL=info

# ============================================================
# DATABASE - PostgreSQL via Prisma
# ============================================================

# Connection string format:
# postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=SCHEMA
# Example: postgresql://evomap:password@localhost:5432/evomap?schema=public
#
# Parameters:
#   USER      - PostgreSQL username
#   PASSWORD  - PostgreSQL password
#   HOST      - Database host (default: localhost)
#   PORT      - Database port (default: 5432)
#   DATABASE  - Database name (default: evomap)
#   schema    - Database schema (default: public)
#
# For local dev, use: postgresql://postgres:password@localhost:5432/evomap
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/evomap?schema=public"

# ============================================================
# REDIS - BullMQ job queue + caching
# ============================================================

# Redis connection URL
# Format: redis://HOST:PORT[/DB]
# DB is optional, 0-15 (default: 0)
# Example: redis://localhost:6379/0
REDIS_URL="redis://localhost:6379"

# ============================================================
# AI SERVICES (Optional)
# ============================================================

# OpenAI API key for AI-powered features:
# - GDI score calculation
# - Semantic search / embeddings
# - Asset similarity detection
# - Smart content generation
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=""

# ============================================================
# NEO4J - Knowledge Graph (Optional)
# ============================================================

# Neo4j connection for graph-based features:
# - Asset relationship discovery
# - Agent network topology
# - Knowledge graph queries
# Requires: FEATURE_NEO4J_ENABLED=true
NEO4J_URI="bolt://localhost:7687"
NEO4J_USER="neo4j"
NEO4J_PASSWORD=""

# ============================================================
# S3 / OBJECT STORAGE (Optional)
# ============================================================

# S3-compatible object storage for:
# - Asset file uploads
# - Map data exports
# - User avatars and images
# - Backup archives
# Supports AWS S3, MinIO, Cloudflare R2, etc.
S3_ENDPOINT=""           # S3 endpoint URL (empty = use AWS default)
S3_REGION="us-east-1"    # AWS region
S3_ACCESS_KEY=""         # AWS access key ID
S3_SECRET_KEY=""         # AWS secret access key
S3_BUCKET="evomap-assets"  # S3 bucket name
S3_PUBLIC_URL=""         # Public CDN URL (optional, e.g. https://cdn.example.com)

# ============================================================
# SECURITY - Secrets (Required for production)
# ============================================================

# Node secret: 64-character hex string for node-to-node authentication
# Generate with: openssl rand -hex 32
# Used for: A2A protocol node identity verification
NODE_SECRET=""

# Session secret: 64-character hex string for signing user sessions
# Generate with: openssl rand -hex 32
# Used for: HTTP session cookies, CSRF tokens
SESSION_SECRET=""

# ============================================================
# RATE LIMITING
# ============================================================

# Maximum requests per time window per IP/user
RATE_LIMIT_MAX=100

# Time window in milliseconds (default: 60000 = 1 minute)
# 100 req/min for anonymous, 1000 for authenticated, 10000 for paid
RATE_LIMIT_WINDOW_MS=60000

# ============================================================
# FEATURE FLAGS - Enable/disable optional features
# ============================================================

# Set to "true" to enable Neo4j knowledge graph features
# Requires: NEO4J_URI, NEO4J_USER, NEO4J_PASSWORD configured
FEATURE_NEO4J_ENABLED="false"

# Set to "true" to enable S3 asset storage
# Requires: S3_* variables configured above
FEATURE_S3_ENABLED="false"

# ============================================================
# SUBSCRIPTION & BILLING
# ============================================================

# Stripe API key (for payment processing)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Pricing plan IDs (from Stripe dashboard)
STRIPE_PRICE_PRO="price_..."
STRIPE_PRICE_TEAM="price_..."
STRIPE_PRICE_ENTERPRISE="price_..."

# ============================================================
# EMAIL (Optional)
# ============================================================

# SMTP settings for transactional emails (welcome, reset password, etc.)
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="noreply@evomap.example.com"

# ============================================================
# CORS & ORIGINS
# ============================================================

# Allowed CORS origins (comma-separated, no spaces)
# Use "all" for development, specific domains for production
CORS_ORIGINS="http://localhost:3002"

# ============================================================
# MONITORING & OBSERVABILITY
# ============================================================

# Grafana/Prometheus metrics endpoint (default: /metrics)
METRICS_ENABLED="true"
METRICS_PATH="/metrics"

# Sentry DSN for error tracking (optional)
SENTRY_DSN=""
SENTRY_ENVIRONMENT="development"

# ============================================================
# DEVELOPMENT OVERRIDES
# ============================================================

# Skip email verification during development
DEV_SKIP_EMAIL_VERIFY="false"

# Seed demo data on first start
DEV_SEED_DATA="false"
