{
  "version": 2,
  "builds": [
    {
      "src": "dist/index.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["dist/**", "ui/**"]
      }
    }
  ],
  "routes": [
    { "src": "/api/v2/(.*)", "dest": "/dist/index.js" },
    { "src": "/a2a/(.*)", "dest": "/dist/index.js" },
    { "src": "/market/(.*)", "dest": "/dist/index.js" },
    { "src": "/arena/(.*)", "dest": "/dist/index.js" },
    { "src": "/ui/(.*)", "dest": "/dist/index.js" },
    { "src": "/(.*)", "dest": "/frontend/$1" }
  ],
  "env": {
    "NEXT_PUBLIC_API_URL": "https://my-evo.vercel.app"
  },
  "github": {
    "enabled": true
  }
}
