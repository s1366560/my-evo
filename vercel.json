{
  "version": 2,
  "builds": [
    {
      "src": "src/index.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "src/index.ts"
    }
  ],
  "installCommand": "rm -rf node_modules package-lock.json && npm install",
  "buildCommand": "npm run build",
  "devCommand": "npx tsx src/index.ts"
}
