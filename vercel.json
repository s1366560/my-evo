{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "/api/(.*)", "dest": "dist/index.js" }
  ],
  "env": {
    "NODE_ENV": "production"
  },
  "github": {
    "enabled": true
  }
}
