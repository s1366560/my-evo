{
  "version": 2,
  "rootDirectory": "frontend",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "installCommand": "npm install",
  "devCommand": "npm run dev",
  "routes": [
    { "handle": "filesystem" },
    { "src": "/api/(.*)", "dest": "dist/index.js" }
  ],
  "env": {
    "NEXT_PUBLIC_API_URL": "https://my-evo.vercel.app"
  },
  "github": {
    "enabled": true
  }
}
