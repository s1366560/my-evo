{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "dist/index.js" }
  ],
  "env": {
    "NEXT_PUBLIC_API_URL": "https://my-evo.vercel.app"
  },
  "github": {
    "enabled": true
  }
}
